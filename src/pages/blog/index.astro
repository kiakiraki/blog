---
import Layout from '@/layouts/Layout.astro';
import PostCard from '@/components/PostCard.astro';
import { CATEGORIES, POSTS_PER_PAGE } from '@/consts';
import { getPostsForPage, getCategoryCounts } from '@/utils/posts';
import { jsonLdStringify } from '@/utils/jsonld';

export const prerender = true;

// Page 1 shows first POSTS_PER_PAGE posts
const { posts, totalPosts, totalPages } = await getPostsForPage(1, POSTS_PER_PAGE);
const categoryCounts = await getCategoryCounts();
const structuredBlogList = jsonLdStringify({
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'ブログ記事一覧',
  url: Astro.site ? new URL(Astro.url).toString() : '',
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: posts.length,
    itemListElement: posts.map((post, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      url: Astro.site ? new URL(`/blog/${post.id}/`, Astro.site).toString() : `/blog/${post.id}/`,
      name: post.data.title,
    })),
  },
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'ホーム',
        item: Astro.site ? new URL('/', Astro.site).toString() : '/',
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'ブログ',
        item: Astro.site ? new URL('/blog/', Astro.site).toString() : '/blog/',
      },
    ],
  },
});
---

<Layout description="趣味についての雑多な記録" title="ブログ記事一覧">
  <div class="container mx-auto px-4 py-16">
    <div class="max-w-6xl mx-auto">
      <script is:inline set:html={structuredBlogList} type="application/ld+json" />
      <!-- Header -->
      <div class="text-center mb-16 animate-fade-in">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-6">
          ブログ記事一覧
        </h1>
        <p class="text-lg text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
          趣味についての雑多な記録
        </p>
        <div class="section-label justify-center mt-6 max-w-xs mx-auto">
          <span>Blog</span>
        </div>
      </div>

      <!-- Category Filter -->
      <div class="mb-12 animate-fade-in-delay-1">
        <div class="flex flex-wrap justify-center gap-3">
          <a
            class="px-4 py-2 rounded-full text-sm font-medium transition-colors duration-200 bg-primary-600 text-white"
            href="/blog/"
          >
            すべて ({totalPosts})
          </a>
          {
            CATEGORIES.map(category => (
              <a
                class="category-chip px-4 py-2 rounded-full text-sm font-medium transition-all duration-200 hover:opacity-80"
                data-category={category}
                href={`/category/${category}/`}
              >
                {category} ({categoryCounts[category]})
              </a>
            ))
          }
        </div>
      </div>

      <!-- Posts Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 animate-fade-in-delay-2">
        {posts.map(post => <PostCard post={post} />)}
      </div>

      <!-- Pagination -->
      {
        totalPages > 1 && (
          <nav
            aria-label="ページネーション"
            class="mt-16 flex justify-center items-center gap-2"
            id="pagination"
          >
            {Array.from({ length: totalPages }, (_, i) => i + 1).map(page => (
              <a
                class:list={[
                  'px-4 py-2 rounded-lg transition-colors',
                  {
                    'bg-primary-600 text-white': page === 1,
                    'bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700':
                      page !== 1,
                  },
                ]}
                href={page === 1 ? '/blog/' : `/blog/page/${page}/`}
              >
                {page}
              </a>
            ))}

            <a
              class="px-4 py-2 rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors"
              href="/blog/page/2/"
            >
              次へ →
            </a>
          </nav>
        )
      }
    </div>
  </div>
</Layout>
