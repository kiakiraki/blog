---
interface Props {
  date: Date | string;
}

const { date } = Astro.props;

// 無効な日付を現在日付で代替すると誤った情報を表示してしまうため、その場合は何も表示しない
const parsed = date instanceof Date ? date : new Date(date);
const validDate = Number.isNaN(parsed.getTime()) ? null : parsed;
---

{
  validDate && (
    <time datetime={validDate.toISOString()}>
      {validDate.toLocaleDateString('ja-JP', {
        year: 'numeric',
        month: 'long',
        day: 'numeric',
      })}
    </time>
  )
}
