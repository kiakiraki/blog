---
import type { Category } from '../consts';

interface Props {
  category: Category;
  size?: 'sm' | 'md';
  class?: string;
}

const { category, size = 'sm', class: className } = Astro.props;

const sizeClasses = size === 'md' ? 'px-3 py-1 text-sm' : 'px-2 py-0.5 text-xs';
---

<span
  class:list={['category-chip inline-block rounded-full font-medium', sizeClasses, className]}
  data-category={category}
>
  {category}
</span>
